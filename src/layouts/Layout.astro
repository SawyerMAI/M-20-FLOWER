---
import { ViewTransitions } from 'astro:transitions';
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'M-20 FLOWER & COFFEE',
  description = '独立系クリエイティブ・フローラルデザインアトリエ',
} = Astro.props;

const currentPath = Astro.url.pathname;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href={`${base}/favicon.svg`} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;700;900&family=Playfair+Display:ital,wght@0,400;0,700;1,400;1,700&family=Noto+Serif+JP:wght@400;700&display=swap"
      rel="stylesheet"
    />
    <ViewTransitions />
  </head>
  <body>
    <nav class="site-nav">
      <span class="nav-coord">X.6204 Y.9513</span>
      <div class="nav-tagline">
        <span>独立系クリエイティブ・スタジオ</span>
        <span>フローラルデザインアトリエ</span>
      </div>
      <ul class="nav-links">
        <li><a href={`${base}/`} aria-current={currentPath === `${base}/` ? 'page' : undefined}>ホーム</a></li>
        <li>
          <a
            href={`${base}/works`}
            aria-current={currentPath.startsWith(`${base}/works`) ? 'page' : undefined}
          >作品集</a>
        </li>
        <li>
          <a href={`${base}/about`} aria-current={currentPath === `${base}/about` ? 'page' : undefined}>概要</a>
        </li>
        <li>
          <a href={`${base}/contact`} aria-current={currentPath === `${base}/contact` ? 'page' : undefined}>お問い合わせ</a>
        </li>
      </ul>
      <button class="nav-menu-btn" aria-label="メニューを開く" aria-expanded="false">☰</button>
    </nav>

    <div class="nav-overlay" aria-hidden="true">
      <button class="nav-overlay-close" aria-label="メニューを閉じる">✕</button>
      <ul class="nav-overlay-links">
        <li><a href={`${base}/`}>ホーム</a></li>
        <li><a href={`${base}/works`}>作品集</a></li>
        <li><a href={`${base}/about`}>概要</a></li>
        <li><a href={`${base}/contact`}>お問い合わせ</a></li>
      </ul>
      <span class="nav-overlay-label">M-20 FLOWER & COFFEE</span>
    </div>

    <slot />

    <footer class="site-footer">
      <span class="footer-mono">X.0204 Y.0113</span>
      <span class="footer-mono">M-20 FLOWER & COFFEE</span>
      <span class="footer-mono">[{new Date().getFullYear()}]</span>
    </footer>
  </body>
</html>

<script>
  function initNav() {
    const btn = document.querySelector('.nav-menu-btn') as HTMLButtonElement | null;
    const overlay = document.querySelector('.nav-overlay') as HTMLElement | null;
    const closeBtn = document.querySelector('.nav-overlay-close') as HTMLButtonElement | null;

    if (!btn || !overlay || !closeBtn) return;

    const open = () => {
      overlay.classList.add('is-open');
      overlay.setAttribute('aria-hidden', 'false');
      btn.setAttribute('aria-expanded', 'true');
      document.body.style.overflow = 'hidden';
    };
    const close = () => {
      overlay.classList.remove('is-open');
      overlay.setAttribute('aria-hidden', 'true');
      btn.setAttribute('aria-expanded', 'false');
      document.body.style.overflow = '';
    };

    btn.addEventListener('click', open);
    closeBtn.addEventListener('click', close);
    overlay.querySelectorAll('a').forEach(a => a.addEventListener('click', close));
  }

  initNav();
  document.addEventListener('astro:after-swap', initNav);
</script>
