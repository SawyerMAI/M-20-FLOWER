---
import { ViewTransitions } from 'astro:transitions';
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'MAISON — フローラルデザインスタジオ',
  description = '独立系クリエイティブ・フローラルデザインアトリエ',
} = Astro.props;

const currentPath = Astro.url.pathname;
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;700;900&family=Playfair+Display:ital,wght@0,400;0,700;1,400;1,700&family=Noto+Serif+JP:wght@400;700&display=swap"
      rel="stylesheet"
    />
    <ViewTransitions />
  </head>
  <body>
    <nav class="site-nav">
      <span class="nav-coord">X.6204 Y.9513</span>
      <div class="nav-tagline">
        <span>独立系クリエイティブ・スタジオ</span>
        <span>フローラルデザインアトリエ</span>
      </div>
      <ul class="nav-links">
        <li><a href="/" aria-current={currentPath === '/' ? 'page' : undefined}>ホーム</a></li>
        <li>
          <a
            href="/works"
            aria-current={currentPath.startsWith('/works') ? 'page' : undefined}
          >作品集</a>
        </li>
        <li>
          <a href="/about" aria-current={currentPath === '/about' ? 'page' : undefined}>概要</a>
        </li>
        <li>
          <a href="/contact" aria-current={currentPath === '/contact' ? 'page' : undefined}>お問い合わせ</a>
        </li>
      </ul>
    </nav>

    <slot />

    <footer class="site-footer">
      <span class="footer-mono">X.0204 Y.0113</span>
      <span class="footer-mono">MAISON® STUDIO</span>
      <span class="footer-mono">[{new Date().getFullYear()}]</span>
    </footer>
  </body>
</html>
